NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hr_harmony_hub?retryWrites=true&w=majority&appName=Cluster0

JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=1d

ADMIN_EMAIL=admin@hrportal.com
ADMIN_PASSWORD=ChangeThisStrongPassword123!

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM="HR Harmony Hub <no-reply@hrharmonyhub.com>"

COMPANY_NAME="Arihant Dream Infra Project Ltd."
COMPANY_SUPPORT_EMAIL="support@your-domain.com"
COMPANY_LOGO_URL="https://cdn.your-domain.com/company-logo.png"
# Optional hosted fallback logo used only when COMPANY_LOGO_URL is invalid or empty.
COMPANY_FALLBACK_LOGO_URL="https://cdn.your-domain.com/company-logo-fallback.png"

# Frontend URL for CORS
CLIENT_URL=http://localhost:8080
